{
  "operationId": "listEntities",
  "method": "GET",
  "path": "/v3/entities",
  "summary": "List entity profiles",
  "description": "Lists KYBed entity profiles. Requires an active platform-admin session.",
  "tags": [
    "Entities"
  ],
  "parameters": [
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "example": 20
    },
    {
      "name": "offset",
      "in": "query",
      "required": false,
      "example": 0
    },
    {
      "name": "query",
      "in": "query",
      "required": false,
      "example": "string"
    }
  ],
  "responses": {
    "200": {
      "description": "Entity profile page.",
      "schema": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entity"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      }
    },
    "401": {
      "description": "Missing, invalid, or expired platform-admin session.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    },
    "403": {
      "description": "Authenticated session exists, but platform-admin access is not active.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    }
  }
}