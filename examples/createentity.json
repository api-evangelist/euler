{
  "operationId": "createEntity",
  "method": "POST",
  "path": "/v3/entities",
  "summary": "Create entity profile",
  "description": "Creates a KYBed entity profile. Requires a platform-admin session and CSRF token.",
  "tags": [
    "Entities"
  ],
  "responses": {
    "201": {
      "description": "Entity profile was created.",
      "schema": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Entity"
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      }
    },
    "400": {
      "description": "Malformed JSON request body.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    },
    "401": {
      "description": "Missing, invalid, or expired platform-admin session.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    },
    "403": {
      "description": "Inactive platform-admin access, missing CSRF token, or mismatched CSRF token.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    },
    "409": {
      "description": "Entity slug already exists.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    },
    "422": {
      "description": "Missing or invalid entity field.",
      "schema": {
        "$ref": "#/components/schemas/ErrorResponse"
      }
    }
  }
}