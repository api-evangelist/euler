{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataIssue",
  "type": "object",
  "properties": {
    "code": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error"
      ]
    },
    "message": {
      "type": "string"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "object",
            "additionalProperties": true
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "source": {
      "type": "string"
    },
    "originalValue": {},
    "normalizedValue": {}
  }
}