{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntrinsicApyHistoryMeta",
  "type": "object",
  "properties": {
    "chainId": {
      "type": "string"
    },
    "asset": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "resolution": {
      "type": "string",
      "enum": [
        "1h",
        "1d"
      ]
    },
    "startTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "endTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}