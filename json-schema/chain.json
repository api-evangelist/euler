{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chain",
  "type": "object",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "nullable": true,
      "description": "Optional chain health status."
    }
  }
}